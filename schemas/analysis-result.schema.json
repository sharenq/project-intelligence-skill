{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analysis Result",
  "description": "核心分析引擎的統一輸出結構，適用於所有 mode",
  "type": "object",
  "required": ["summary", "intent", "confidence", "open_questions"],
  "properties": {
    "summary": {
      "type": "string",
      "description": "本次分析的一段式摘要"
    },
    "intent": {
      "type": "string",
      "description": "本次變更或程式碼的主要意圖"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "整體分析的信心程度"
    },
    "affected_modules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "受影響的模組名稱（對應 project profile 中的 modules）"
    },
    "behavioral_observations": {
      "type": "array",
      "description": "從程式碼中觀察到的行為模式或規則候選",
      "items": {
        "type": "object",
        "required": ["title", "confidence"],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "evidence": {
            "type": "object",
            "description": "支持此觀察的具體證據",
            "properties": {
              "file_path": {
                "type": "string",
                "description": "相關檔案路徑"
              },
              "function_name": {
                "type": "string",
                "description": "相關函式或方法名稱"
              },
              "description": {
                "type": "string",
                "description": "證據描述與觀察到的關聯"
              }
            },
            "required": ["description"],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "description": "識別到的風險",
      "items": {
        "type": "object",
        "required": ["title", "severity"],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "affected_area": {
            "type": "string"
          },
          "test_cost": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "驗證此風險所需的測試成本（搭配 severity 做成本效益判斷）"
          }
        },
        "additionalProperties": false
      }
    },
    "suggested_tests": {
      "type": "array",
      "items": { "type": "string" },
      "description": "建議驗證的測試方向"
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "分析過程中做出的假設（必須明確列出）"
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "無法從現有資訊回答的問題"
    },
    "mode_specific": {
      "type": "object",
      "description": "各 mode 的專屬輸出欄位（由 mode 定義結構）",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
